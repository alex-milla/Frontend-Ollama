# Frontend-Ollama — Configuración
# Copia este archivo a config.env y ajusta los valores

# URL de la API de Ollama (sin barra final)
OLLAMA_HOST=http://192.168.1.100:11434

# Clave secreta para sesiones Flask — CAMBIA ESTO antes de poner en producción
# Genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-esto-por-un-valor-aleatorio-seguro

# Ruta absoluta a la base de datos SQLite
DB_PATH=/opt/frontend-ollama/data/ollama-chat.db

# Directorio de uploads (Fase 6)
UPLOAD_FOLDER=/opt/frontend-ollama/data/uploads

# Tamaño máximo de upload en bytes (10 MB)
MAX_CONTENT_LENGTH=10485760

# Puerto de Gunicorn (solo interno, NGINX hace el proxy)
GUNICORN_PORT=5000
